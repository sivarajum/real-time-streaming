# Real-Time Streaming Platform — Environment Variables
# Copy to .env and adjust values as needed.

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit UI
UI_PORT=8501
API_URL=http://localhost:8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Background producer interval (seconds between batches)
PRODUCE_INTERVAL=0.1

# Processor window interval (seconds per micro-batch)
PROCESS_INTERVAL=5.0

# Default Kafka-style topic name
DEFAULT_TOPIC=events

# Number of partitions per topic
NUM_PARTITIONS=4
